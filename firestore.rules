// ─── BizSoft Solutions — Firestore Security Rules v2 ─────────
// Paste these in Firebase Console → Firestore → Rules tab
//
// leads : public can CREATE only (website forms);
//         only signed-in admin can read / update / delete.
// plans : public can READ only (live pricing on website);
//         only signed-in admin can create / update / delete.
// ─────────────────────────────────────────────────────────────

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── leads collection ──────────────────────────────────────
    match /leads/{leadId} {

      allow create: if
        // Must have name and phone fields
        request.resource.data.keys().hasAll(['name', 'phone', 'ticketId']) &&

        // name must be a non-empty string
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() < 120 &&

        // phone must be a non-empty string
        request.resource.data.phone is string &&
        request.resource.data.phone.size() > 5 &&
        request.resource.data.phone.size() < 20 &&

        // ticketId must be a string (set by form.js)
        request.resource.data.ticketId is string &&

        // Prevent oversized payloads (max 20 fields)
        request.resource.data.keys().size() <= 20;

      // Only the signed-in admin (console) can read / manage leads
      allow read, update, delete: if request.auth != null;
    }

    // ── plans collection (live pricing) ───────────────────────
    match /plans/{planId} {
      // Anyone can read — the website renders prices from here
      allow read: if true;

      // Only the signed-in admin can manage plans
      allow create, update, delete: if request.auth != null;
    }

    // ── All other collections — deny everything ───────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
